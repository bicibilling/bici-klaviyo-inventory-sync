# Copy to ".env" for local runs (this file is the template; ".env" is gitignored).
# On Render these are set as service environment variables, not from a file.
# Values here are plain (no quotes). Never commit a real .env.

# Shopify store handle (the myshopify subdomain).
SHOPIFY_STORE=la-bicicletta-vancouver

# Shopify Admin API token with read_products scope.
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Shared secret appended to the Klaviyo feed URL (&token=...). Pick any random
# string. Leave unset to leave the endpoint open (inventory counts aren't secret).
FEED_TOKEN=choose-a-random-string

# NOTE: the web service does NOT need a Klaviyo key — Klaviyo calls us, not the
# other way around. (A KLAVIYO_API_KEY is only used for one-off diagnostics.)
